{
  "name": "nexibase",
  "version": "0.6.6",
  "private": true,
  "scripts": {
    "dev": "node scripts/scan-plugins.js && node scripts/scan-layouts.js && node scripts/scan-themes.js && next dev --turbopack",
    "dev:clean": "rm -rf .next && next dev --turbopack",
    "build": "node scripts/scan-plugins.js && node scripts/scan-layouts.js && node scripts/scan-themes.js && next build",
    "start": "next start",
    "lint": "next lint",
    "db:setup": "prisma migrate deploy && prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "postinstall": "prisma generate && node scripts/setup-custom-css.js"
  },
  "dependencies": {
