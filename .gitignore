# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# 사용자 커스터마이징용 app 폴더
# src/app을 복사해서 사용 (app/이 있으면 src/app보다 우선)
/app

# 사용자 커스텀 테마
# src/themes/default를 복사해서 사용
/src/themes/custom

# 사용자 커스텀 CSS (프로젝트별 스타일 오버라이드)
/src/app/custom.css

# 테마 index.ts (prebuild 스크립트로 자동 생성)
/src/themes/index.ts

/public

# Claude Code 관련 파일
.claude/
CLAUDE.md

# 이니시스 샘플 코드 (참고용)
/general_pc/