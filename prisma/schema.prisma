// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 사용자 시스템
// ============================================

// 사용자 테이블
model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique @db.VarChar(255)
  name          String?   @db.VarChar(100)
  nickname      String?   @db.VarChar(100)
  password      String?   @db.VarChar(255) // 소셜 로그인 사용자는 null
  image         String?   @db.VarChar(500) // 프로필 이미지 URL
  phone         String?   @db.VarChar(20)
  level         Int       @default(1) // 사용자 레벨 (게시판 권한용)
  role          String    @default("user") @db.VarChar(20) // user, admin, moderator
  status        String    @default("active") @db.VarChar(20) // active, inactive, banned
  emailVerified DateTime?
  lastLoginAt   DateTime?
  lastLoginIp   String?   @db.VarChar(50)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 관계
  accounts      Account[]
  sessions      UserSession[]
  posts         Post[]
  comments      Comment[]
  reactions     Reaction[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

// 소셜 로그인 계정 연동 테이블
model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String  @db.VarChar(50) // oauth, credentials
  provider          String  @db.VarChar(50) // google, kakao, naver, github
  providerAccountId String  @db.VarChar(255)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.VarChar(255)
  id_token          String? @db.Text
  session_state     String? @db.VarChar(255)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// 세션 테이블
model UserSession {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique @db.VarChar(255)
  userId       Int
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

// ============================================
// 게시판 시스템
// ============================================

// 게시판 테이블
model Board {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(50) // URL용 슬러그 (예: free, notice, qa)
  name        String   @db.VarChar(100) // 게시판 이름
  description String?  @db.VarChar(500) // 게시판 설명
  category    String?  @db.VarChar(50) // 카테고리 (community, support, etc.)

  // 권한 설정 (레벨)
  listLevel   Int      @default(0) // 목록 보기 권한
  readLevel   Int      @default(0) // 글 읽기 권한
  writeLevel  Int      @default(1) // 글 쓰기 권한
  commentLevel Int     @default(1) // 댓글 쓰기 권한

  // 기능 설정
  useComment  Boolean  @default(true) // 댓글 사용
  useReaction Boolean  @default(true) // 반응(좋아요 등) 사용
  useFile     Boolean  @default(true) // 파일 첨부 사용
  useSecret   Boolean  @default(false) // 비밀글 사용

  // 표시 설정
  postsPerPage Int     @default(20) // 페이지당 게시글 수
  sortOrder   String   @default("latest") @db.VarChar(20) // latest, popular, oldest
  isActive    Boolean  @default(true) // 활성화 여부

  // 통계
  postCount   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 관계
  posts       Post[]

  @@index([slug])
  @@index([category])
  @@index([isActive])
  @@map("boards")
}

// 게시글 테이블
model Post {
  id          Int      @id @default(autoincrement())
  boardId     Int
  authorId    Int

  title       String   @db.VarChar(200)
  content     String   @db.Text

  // 상태
  status      String   @default("published") @db.VarChar(20) // draft, published, hidden, deleted
  isNotice    Boolean  @default(false) // 공지글 여부
  isSecret    Boolean  @default(false) // 비밀글 여부

  // 통계
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  commentCount Int     @default(0)

  // 메타 정보
  ip          String?  @db.VarChar(50)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 관계
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  reactions   Reaction[]

  @@index([boardId])
  @@index([authorId])
  @@index([status])
  @@index([createdAt])
  @@map("posts")
}

// 댓글 테이블
model Comment {
  id          Int      @id @default(autoincrement())
  postId      Int
  authorId    Int
  parentId    Int?     // 대댓글용 부모 댓글 ID

  content     String   @db.Text

  // 상태
  status      String   @default("published") @db.VarChar(20) // published, hidden, deleted
  isSecret    Boolean  @default(false) // 비밀 댓글

  // 통계
  likeCount   Int      @default(0)

  // 메타 정보
  ip          String?  @db.VarChar(50)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 관계
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent      Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")
  reactions   Reaction[]

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([createdAt])
  @@map("comments")
}

// 반응(좋아요 등) 테이블
model Reaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  postId      Int?
  commentId   Int?

  type        String   @db.VarChar(20) // like, dislike, love, haha, sad, angry

  createdAt   DateTime @default(now())

  // 관계
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment     Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  // 한 사용자가 같은 게시글/댓글에 같은 타입 반응은 한 번만
  @@unique([userId, postId, type])
  @@unique([userId, commentId, type])
  @@index([postId])
  @@index([commentId])
  @@map("reactions")
}

// ============================================
// 콘텐츠 관리 시스템
// ============================================

// 일반 콘텐츠 테이블 (회사소개, About 등)
model Content {
  id        Int      @id @default(autoincrement())
  slug      String   @unique @db.VarChar(100)
  title     String   @db.VarChar(200)
  content   String   @db.LongText
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isPublic])
  @@map("contents")
}

// 약관/정책 테이블 (버전 관리)
model Policy {
  id        Int      @id @default(autoincrement())
  slug      String   @db.VarChar(100)  // "terms", "privacy"
  version   String   @db.VarChar(20)   // "1.0", "1.1"
  title     String   @db.VarChar(200)
  content   String   @db.LongText
  isActive  Boolean  @default(false)   // 슬러그당 하나만 true
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, version])
  @@index([slug, isActive])
  @@map("policies")
}
